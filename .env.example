# LambdaX Environment Configuration

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=true

# Server
HOST=0.0.0.0
PORT=8000

# Policy
POLICY_PATH=policy.yaml

# Cache
CACHE_TTL=300
CACHE_MAXSIZE=1000

# Timeouts
GUARD_TIMEOUT=5.0

# Models (optional - for custom model paths)
# MODEL_CACHE_DIR=/path/to/models

# API Keys (if using external services)
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
